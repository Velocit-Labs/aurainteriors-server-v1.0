# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/aura_interiors_db

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Frontend URLs (CORS/Redirects)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
# Production example:
# FRONTEND_URL=https://aurainteriors.live
# ADMIN_URL=https://admin.aurainteriors.live

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Email Service (Brevo)
BREVO_SMTP_LOGIN=your_brevo_smtp_login
BREVO_SMTP_KEY=your_brevo_smtp_key
EMAIL_FROM="Aura Interiors <support@aurainteriors.live>"

# Admin Credentials (For Seeding)
ADMIN_EMAIL=admin@aurainteriors.com
ADMIN_PASSWORD=Admin@123456

# Firebase Push Notifications
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key_here"

# Redis
REDIS_PORT=6379

# Backend URL (For Callbacks)
BACKEND_URL=http://localhost:3001

# Payment Gateway (eSewa)
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
